# Optional LLM providers. LOCAL expert-system mode works without API keys.
GROQ_API_KEY=
GEMINI_API_KEY=

# Optional model menus. Override these when providers change model availability.
GROQ_MODELS=llama-3.3-70b-versatile,openai/gpt-oss-20b,moonshotai/kimi-k2-instruct
GEMINI_MODELS=gemini-3.5-flash,gemini-2.5-flash-lite,gemini-2.5-pro

# Internal Flask API used by Streamlit.
API_PORT=5000
FULFILLTWIN_API_URL=http://127.0.0.1:5000

# Runtime settings.
MODEL_SEED=42
TRAINING_ROWS=3500
MAX_MEMORY_RECORDS=250
