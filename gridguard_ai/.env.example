# Embedded GridGuard configuration. Copy desired values into ../.env (the suite root).
# GridGuard runtime
GRIDGUARD_DATA_MODE=synthetic
GRIDGUARD_FORECAST_HOURS=24
GRIDGUARD_API_PORT=8000
GRIDGUARD_DECISION_PROVIDER=internal_expert_system

# Kaggle historical-data mode
# GRIDGUARD_KAGGLE_DATA_PATH is auto-set to gridguard_ai/data/kaggle/hourly_energy_consumption.csv
GRIDGUARD_KAGGLE_TIMEZONE=America/New_York
GRIDGUARD_KAGGLE_MISSING_POLICY=interpolate

# EIA live-data mode
EIA_API_KEY=
GRIDGUARD_EIA_RESPONDENT=ISNE
GRIDGUARD_EIA_HISTORY_HOURS=2160

# Persistence: json or postgresql
GRIDGUARD_PERSISTENCE_MODE=json
DATABASE_URL=
# GRIDGUARD_JSON_PATH is auto-set to gridguard_ai/data/runtime/decisions.json

# JSON-backed decision memory and token ledger
# GRIDGUARD_MEMORY_PATH is auto-set to gridguard_ai/data/runtime/decision_memory.json
GRIDGUARD_MEMORY_MAX_RECORDS=200
# GRIDGUARD_TOKEN_LEDGER_PATH is auto-set to gridguard_ai/data/runtime/token_usage.json

# Local RAG
# GRIDGUARD_RAG_DOCS_DIR is auto-set to gridguard_ai/docs/rag


# GroqCloud (not the same service as Grok/xAI)
GROQ_API_KEY=
GRIDGUARD_GROQ_MODEL=openai/gpt-oss-120b
GRIDGUARD_GROQ_TOKEN_BUDGET=100000

# Google Gemini API
GEMINI_API_KEY=
GRIDGUARD_GEMINI_MODEL=gemini-2.5-flash
GRIDGUARD_GEMINI_TOKEN_BUDGET=100000

# Railway assigns PORT automatically
PORT=8501
