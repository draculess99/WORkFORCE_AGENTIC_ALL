# Optional API keys for LLM/agent features.
# Copy this file to .env and fill in only the providers you actually use.

# Google Gemini / Google GenAI
GOOGLE_API_KEY=
GEMINI_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Groq
GROQ_API_KEY=

# Local app settings
STREAMLIT_SERVER_PORT=8501

# GridGuard AI embedded page
GRIDGUARD_DATA_MODE=synthetic
GRIDGUARD_FORECAST_HOURS=24
GRIDGUARD_DECISION_PROVIDER=internal_expert_system
GRIDGUARD_KAGGLE_TIMEZONE=America/New_York
GRIDGUARD_KAGGLE_MISSING_POLICY=interpolate
EIA_API_KEY=
GRIDGUARD_EIA_RESPONDENT=ISNE
GRIDGUARD_EIA_HISTORY_HOURS=2160
GRIDGUARD_PERSISTENCE_MODE=json
DATABASE_URL=
GRIDGUARD_MEMORY_MAX_RECORDS=200
GRIDGUARD_GROQ_MODEL=openai/gpt-oss-120b
GRIDGUARD_GROQ_TOKEN_BUDGET=100000
GRIDGUARD_GEMINI_MODEL=gemini-2.5-flash
GRIDGUARD_GEMINI_TOKEN_BUDGET=100000

# GridGuard file paths are automatically isolated under gridguard_ai/.
# Override only when you intentionally want a different storage location.
# GRIDGUARD_KAGGLE_DATA_PATH=gridguard_ai/data/kaggle/hourly_energy_consumption.csv
# GRIDGUARD_JSON_PATH=gridguard_ai/data/runtime/decisions.json
# GRIDGUARD_MEMORY_PATH=gridguard_ai/data/runtime/decision_memory.json
# GRIDGUARD_TOKEN_LEDGER_PATH=gridguard_ai/data/runtime/token_usage.json
# GRIDGUARD_RAG_DOCS_DIR=gridguard_ai/docs/rag

# FulfillTwin AI embedded page
# false = recommended single-service in-process mode
FULFILLTWIN_USE_HTTP_API=false
MODEL_SEED=42
TRAINING_ROWS=3500
MAX_MEMORY_RECORDS=250
GROQ_MODELS=llama-3.3-70b-versatile,openai/gpt-oss-20b,moonshotai/kimi-k2-instruct
GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.5-pro
# MEMORY_FILE defaults to fulfilltwin_ai/fulfilltwin/backend/storage/memory.json
